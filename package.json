{
  "name": "aradobot",
  "private": true,
  "version": "1.0.0",
  "description": "Production-ready AI book knowledge SaaS with deterministic RAG over uploaded PDFs.",
  "packageManager": "pnpm@10.34.3",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "node scripts/start.mjs",
    "build": "pnpm --filter @aradobot/api build && pnpm --filter @aradobot/web build",
    "typecheck": "pnpm --filter @aradobot/api typecheck && pnpm --filter @aradobot/web typecheck",
    "test": "pnpm --filter @aradobot/api test && pnpm --filter @aradobot/web test"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.20.0",
    "pnpm": ">=10.34.3 <11"
  }
}
