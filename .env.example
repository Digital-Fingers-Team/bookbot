# API
PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/bookbotd
CLIENT_ORIGIN=http://localhost:3000
ADMIN_API_KEY=change-me
AUTH_JWT_SECRET=change-me-bookbot-auth-secret
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_EMBEDDING_DIMENSIONS=1536

# OCR fallback (reads rendered page images when the PDF text layer is broken)
OCR_ENABLED=true
# auto = cloud vision model, falling back to local tesseract when out of credits.
# openrouter = cloud only. local = offline tesseract only (free, no key needed).
OCR_PROVIDER=auto
OCR_LOCAL_LANGS=ara+eng
OCR_VISION_MODEL=google/gemini-2.5-flash
OCR_MIN_TEXT_SCORE=65
OCR_RENDER_SCALE=2
OCR_MAX_PAGES=600
# Parallelism: OCR pages in flight (global) and books processed at once.
OCR_CONCURRENCY=6
PROCESSING_CONCURRENCY=2
OCR_MAX_OUTPUT_TOKENS=4096
ATLAS_VECTOR_INDEX_NAME=chunk_embedding_vector_index
VECTOR_CANDIDATE_MAX=300
VECTOR_NUM_CANDIDATES_MULTIPLIER=20
PDF_STORAGE_DIR=storage/pdfs
UPLOAD_MAX_MB=25
UPLOAD_MAX_FILES=10

# OMP (Open Monograph Press) integration
OMP_BASE_URL=http://localhost:8091
OMP_CONTEXT_PATH=index
# Generate in OMP: admin Profile → API Key
OMP_API_TOKEN=
# Encrypts the per-user OMP password we store (AES-256-GCM). Use a long random value.
OMP_USER_SECRET=
# Shared secret for one-time SSO login tokens; MUST match bookbot_sso_secret in OMP config.
OMP_SSO_SECRET=
# Default ISO country for OMP author registration when not collected in bookbot.
OMP_DEFAULT_COUNTRY=EG

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
